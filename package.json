{
  "name": "freshdesk-mcp",
  "version": "1.1.0",
  "description": "MCP server for Freshdesk API v2 integration — manage tickets, contacts, agents, companies, and conversations",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "freshdesk-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:enhanced": "tsc --noEmit false",
    "dev": "tsx --watch src/index.ts",
    "dev:enhanced": "tsx --watch src/index-enhanced.ts",
    "start": "node dist/index.js",
    "start:enhanced": "node dist/index-enhanced.js",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:watch": "jest --coverage --watch",
    "test:coverage:threshold": "jest --coverage --coverageThreshold='{}' --passWithNoTests",
    "test:unit": "jest tests/unit tests/api tests/auth tests/core tests/tools tests/utils --coverage",
    "test:integration": "jest tests/integration --coverage",
    "test:e2e": "tsx tests/e2e/freshdesk-tools.e2e.test.ts",
    "test:security": "jest tests/security --coverage",
    "test:mcp:all": "jest --config jest.config.mcp.js tests/mcp --coverage",
    "test:mcp:process": "jest --config jest.config.mcp.js tests/mcp/real-process.test.ts",
    "test:mcp:protocol": "jest --config jest.config.mcp.js tests/mcp/protocol-compliance.test.ts",
    "test:mcp:sdk": "jest --config jest.config.mcp.js tests/mcp/sdk-integration.test.ts",
    "test:mcp:performance": "jest --config jest.config.mcp.js tests/mcp/performance.test.ts",
    "test:mcp:errors": "jest --config jest.config.mcp.js tests/mcp/error-recovery.test.ts",
    "test:mcp:workflows": "jest --config jest.config.mcp.js tests/mcp/tool-workflows.test.ts",
    "test:mcp:auth": "jest --config jest.config.mcp.js tests/mcp/authentication.test.ts",
    "test:mcp:health": "jest --config jest.config.mcp.js tests/mcp/health-monitoring.test.ts",
    "coverage:report": "node scripts/generate-coverage-report.js",
    "coverage:open": "open coverage/lcov-report/index.html",
    "test:mcp": "tsx scripts/test-mcp-client.ts",
    "test:mcp:mock": "tsx scripts/test-mcp-mock.ts",
    "test:mcp:inspector": "./scripts/test-mcp-inspector.sh",
    "test:mcp:claude": "./scripts/test-claude-desktop.sh",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "freshdesk",
    "api",
    "typescript",
    "customer-support",
    "helpdesk",
    "model-context-protocol",
    "ai",
    "llm"
  ],
  "author": "Stanislav Shymanskyi <taysic@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enreign/freshdeck-mcp.git"
  },
  "homepage": "https://github.com/Enreign/freshdeck-mcp#readme",
  "bugs": {
    "url": "https://github.com/Enreign/freshdeck-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "1.15.0",
    "dotenv": "^16.5.0",
    "jsonschema": "^1.4.1",
    "lru-cache": "^10.0.1",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.3",
    "zod": "^3.22.0"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.7"
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/nock": "^10.0.3",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "nock": "^14.0.5",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.2.2"
  }
}
